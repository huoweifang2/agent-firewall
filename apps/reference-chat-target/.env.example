# Required
GEMINI_API_KEY=
# Model (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Mode: "raw" (direct Gemini) or "protected" (via Agent-Firewall)
APP_MODE=raw

# Protected mode settings (only needed when APP_MODE=protected)
AGENT_FIREWALL_BASE_URL=
AGENT_FIREWALL_API_KEY=

# Feature flags
ENABLE_STREAMING=true
ENABLE_RETRIEVAL=true
ENABLE_TOOLS=false
ENABLE_STRUCTURED_OUTPUT=true
ENABLE_CANARY=true

# Optional static bearer auth (leave empty to disable)
STATIC_AUTH_TOKEN=test-secret-2026

# Server
PORT=8010
MODEL_TIMEOUT=30
