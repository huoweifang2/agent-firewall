flowchart TB
  subgraph S["风险信号"]
    A["Intent<br/>越权 / 泄露 / 注入"]:::runtime
    B["Rules<br/>denylist / 编码 / 长度"]:::proxy
    C["Scanners<br/>LLM Guard / NeMo"]:::llm
    D["PII / Secrets<br/>敏感实体"]:::gate
    E["score_boost<br/>自定义风险提升"]:::audit
  end
  F["风险聚合<br/>risk_score 0-1"]:::gate
  G{"决策规则"}:::gate
  H["BLOCK<br/>denylist 或 risk >= max_risk"]:::block
  I["MODIFY<br/>PII mask / 参数清洗"]:::modify
  J["ALLOW<br/>无高风险信号"]:::allow
  K["解释字段<br/>flags / reason / intent"]:::note

  A --> F
  B --> F
  C --> F
  D --> F
  E --> F
  F --> G
  G --> H
  G --> I
  G --> J
  F --> K

