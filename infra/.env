# ── PostgreSQL ─────────────────────────────────────────
POSTGRES_DB=agent_firewall
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Mode ───────────────────────────────────────────────
# "demo" = MockProvider when no API key
# "real" = External provider required
MODE=demo

# ── Redis ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

DEFAULT_MODEL=deepseek/deepseek-chat

# ── Langfuse ──────────────────────────────────────────
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local

# ── Proxy Service ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/agent_firewall
DEFAULT_POLICY=balanced

# ── Agent Demo ────────────────────────────────────────
PROXY_BASE_URL=http://proxy-service:8000/v1

# ── Test Agents ───────────────────────────────────────
PROXY_URL=http://proxy-service:8000
PROXY_POLICY=balanced

# ── Agent Tracing (leave empty — auto-set by /load-config) ──
# Set these to pre-assign agent IDs for trace collection.
# If empty, agents pick up the ID when /load-config is called.
AGENT_ID_DEMO=
AGENT_ID_PYTHON=
AGENT_ID_LANGGRAPH=

# ── Red Team Benchmark ────────────────────────────────
# 64-hex-char AES-256 key for encrypting auth secrets at rest.
# Auto-generated by `make init` / `make demo` if empty.
BENCHMARK_SECRET_KEY=e8b0251dc6239762e89e57d15e5fbc5091f16b2fd1f2e8a07dd3797056c3e66e
